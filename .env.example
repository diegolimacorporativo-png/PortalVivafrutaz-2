# ─── Banco de Dados ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/vivafrutaz

# Postgres (para docker-compose)
POSTGRES_DB=vivafrutaz
POSTGRES_USER=vivafrutaz
POSTGRES_PASSWORD=changeme

# ─── Sessão ──────────────────────────────────────────────────────
SESSION_SECRET=change_this_to_a_long_random_string_at_least_32_chars

# ─── Ambiente ────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── NF-e / SEFAZ ────────────────────────────────────────────────
# Modo de transmissão: 'mock' (padrão, simula autorização) | 'production' (envia à SEFAZ real)
NFE_SEFAZ_MODE=mock

# Certificado A1 — escolha UMA das duas formas:
#   (a) NFE_CERT_PATH:   caminho de arquivo .pfx no disco
#   (b) NFE_CERT_BASE64: conteúdo do .pfx em base64 (recomendado em Replit Secrets)
NFE_CERT_PATH=/path/to/certificate.pfx
# NFE_CERT_BASE64=
NFE_CERT_PASSWORD=senha_do_certificado

# UF do emitente (default detectado do XML; usado apenas como fallback)
NFE_UF=SP
# Ambiente: 1=Produção | 2=Homologação
NFE_AMBIENTE=2

# Aliases legados (mantidos para compat com versões anteriores)
CERT_PATH=/path/to/certificate.pfx
CERT_PASSWORD=senha_do_certificado
SEFAZ_AMBIENTE=2

# ─── Itaú Bank Integration ───────────────────────────────────────
ITAU_CLIENT_ID= 
ITAU_CLIENT_SECRET=
ITAU_AGENCIA=
ITAU_CONTA=
ITAU_AMBIENTE=sandbox
# sandbox ou producao

# ─── Google Maps (opcional) ──────────────────────────────────────
GOOGLE_MAPS_API_KEY=


# ─── IA / OpenAI (opcional) ──────────────────────────────────────
OPENAI_API_KEY=

#_ NF-e / Certificado Digital (Segurança ) ─────────────────────────────
NFE_CERT_SECRET=your_secret_here 
