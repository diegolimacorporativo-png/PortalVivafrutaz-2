# ─── Banco de Dados ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/vivafrutaz

# Postgres (para docker-compose)
POSTGRES_DB=vivafrutaz
POSTGRES_USER=vivafrutaz
POSTGRES_PASSWORD=changeme

# ─── Sessão ──────────────────────────────────────────────────────
SESSION_SECRET=change_this_to_a_long_random_string_at_least_32_chars

# ─── Ambiente ────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── NF-e / SEFAZ ────────────────────────────────────────────────
CERT_PATH=/path/to/certificate.pfx
CERT_PASSWORD=senha_do_certificado
SEFAZ_AMBIENTE=2
# 1=Produção, 2=Homologação

# ─── Itaú Bank Integration ───────────────────────────────────────
ITAU_CLIENT_ID= 
ITAU_CLIENT_SECRET=
ITAU_AGENCIA=
ITAU_CONTA=
ITAU_AMBIENTE=sandbox
# sandbox ou producao

# ─── Google Maps (opcional) ──────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ─── IA / OpenAI (opcional) ──────────────────────────────────────
OPENAI_API_KEY=
